{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "20.11.0",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://final-backend-mobile-app-2-4sfz.onrender.com"
      }
    },
    "preview": {
      "node": "20.11.0",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://final-backend-mobile-app-2-4sfz.onrender.com"
      },
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "node": "20.11.0",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://final-backend-mobile-app-2-4sfz.onrender.com",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}